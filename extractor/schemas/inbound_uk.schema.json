{
  "schema_name": "inbound_uk",
  "description": "UK inbound deals extracted from IMs and teasers (UK Deal list sheet)",
  "notes": "Column order must match Excel exactly for copy-paste. Light purple columns are left blank (filled manually).",
  "columns": [
    { "name": "Index", "type": "integer", "required": false, "extraction": false, "notes": "Row number, filled manually" },
    { "name": "Week nr.", "type": "integer", "required": false, "extraction": false, "notes": "Filled manually" },
    { "name": "Date received", "type": "date", "format": "yyyy/mm/dd", "required": false, "extraction": false, "notes": "Filled manually" },
    { "name": "Type", "type": "string", "required": false, "notes": "IM or Teaser" },
    { "name": "Strategy", "type": "string", "required": false, "extraction": false, "notes": "Big Box, Office, MLI, Net Lease - filled manually" },
    { "name": "Project Name", "type": "string", "required": true, "notes": "Usually the document name or first slide title" },
    { "name": "Received by", "type": "string", "required": false, "extraction": false, "notes": "Person who received the deal - filled manually" },
    { "name": "Seller", "type": "string", "required": false },
    { "name": "Buy/Sell Side Broker", "type": "string", "required": false, "extraction": false, "notes": "Buy-Side or Sell-Side - filled manually" },
    { "name": "Broker", "type": "string", "required": false, "extraction": false, "notes": "Broker company - filled manually" },
    { "name": "Broker Name", "type": "string", "required": false, "extraction": false, "notes": "Individual broker name - filled manually" },
    { "name": "Country", "type": "string", "required": true, "default": "United Kingdom" },
    { "name": "Location", "type": "string", "required": true, "notes": "City/town name" },
    { "name": "Portfolio", "type": "string", "required": false, "notes": "Yes or No" },
    { "name": "Address", "type": "string", "required": false },
    { "name": "Postal code", "type": "string", "required": false },
    { "name": "Property designation", "type": "string", "required": false, "notes": "UK: often postcode area or land registry reference" },
    { "name": "Year Built", "type": "string", "required": false, "notes": "Construction year or age range as stated, e.g. '2025', '1990-2001', '1970s+' — null if not stated (Task 2 addition)" },
    { "name": "Number of Tenants", "type": "integer", "required": false, "notes": "Count of tenants/lettings if stated — null otherwise (Task 2 addition)" },
    { "name": "Use", "type": "string", "required": true, "notes": "Property type: Industrial, Logistics, Office, Retail, Mixed Use, Parking, etc." },
    { "name": "Leasable area, sq ft", "type": "number", "required": false, "notes": "Area in square feet (UK standard)" },
    { "name": "Base rent incl. index, CCY/sqft", "type": "number", "required": false, "notes": "Rent per sq ft (psf)" },
    { "name": "NOI, CCY", "type": "number", "required": false, "notes": "Net Operating Income / passing rent p.a." },
    { "name": "NOI, CCY/sqft", "type": "number", "required": false, "derived": true },
    { "name": "WAULT, years", "type": "number", "required": false, "notes": "Weighted Average Unexpired Lease Term" },
    { "name": "Economic occupancy rate, %", "type": "string", "required": false, "notes": "Occupancy as percentage string e.g. 95%" },
    { "name": "Yield", "type": "number", "required": false, "notes": "NIY (Net Initial Yield)" },
    { "name": "Deal value, CCY", "type": "number", "required": false, "notes": "Asking price or guide price" },
    { "name": "Deal value, CCY/sqft", "type": "number", "required": false, "derived": true },
    { "name": "Comment", "type": "string", "required": true, "notes": "ONE short sentence (max 20 words) capturing the investment angle — Task 2 tightened from prior 2-3 sentence format" },
    { "name": "Price, CCY", "type": "number", "required": false, "notes": "Actual price if different from deal value" },
    { "name": "Price, CCY/sqft", "type": "number", "required": false, "derived": true },
    { "name": "Yield2", "type": "number", "required": false, "notes": "RY (Reversionary Yield) if stated" },
    { "name": "Link", "type": "string", "required": false }
  ],
  "extraction_fields": [
    "Type",
    "Project Name",
    "Seller",
    "Country",
    "Location",
    "Portfolio",
    "Address",
    "Postal code",
    "Property designation",
    "Use",
    "Leasable area, sq ft",
    "Base rent incl. index, CCY/sqft",
    "NOI, CCY",
    "WAULT, years",
    "Economic occupancy rate, %",
    "Yield",
    "Deal value, CCY",
    "Comment",
    "Yield2"
  ],
  "manual_fields": [
    "Index",
    "Week nr.",
    "Date received",
    "Strategy",
    "Received by",
    "Buy/Sell Side Broker",
    "Broker",
    "Broker Name",
    "Link"
  ]
}
